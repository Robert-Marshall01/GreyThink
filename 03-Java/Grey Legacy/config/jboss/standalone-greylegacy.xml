<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  Grey Legacy — JBoss EAP 7 / WildFly Standalone Configuration (excerpt)
  ============================================================================
  This is a SUBSET of standalone-full.xml containing only the subsystems
  relevant to the Grey Legacy application.  In a real deployment, this would
  be merged into the JBoss standalone-full.xml managed by the operations team.

  Demonstrates:
    1. JNDI DataSource (PostgreSQL)
    2. JMS (ActiveMQ Artemis subsystem)
    3. Security domain (JAAS)
    4. EJB configuration
    5. Web subsystem (Undertow)
    6. Logging subsystem

  These patterns are critical for any engineer maintaining Java EE applications
  deployed on JBoss/WildFly — the most common app server in insurance/finance.

  Typically lives at:
    $JBOSS_HOME/standalone/configuration/standalone-full.xml
  ============================================================================
-->
<server xmlns="urn:jboss:domain:6.0">

    <!-- ================================================================== -->
    <!-- System Properties                                                   -->
    <!-- ================================================================== -->
    <system-properties>
        <property name="greylegacy.environment" value="production"/>
        <property name="greylegacy.batch.export.directory" value="/opt/greylegacy/export"/>
        <property name="greylegacy.jms.broker.url"
                  value="tcp://mq-prod.greylegacy.internal:61616"/>
    </system-properties>

    <!-- ================================================================== -->
    <!-- Datasources Subsystem                                               -->
    <!-- ================================================================== -->
    <!--
        JBoss manages the DataSource and exposes it via JNDI.
        Application code does:
          @Resource(lookup = "java:jboss/datasources/GreyLegacyDS")
          private DataSource dataSource;

        Or in Spring XML:
          <jee:jndi-lookup id="dataSource"
                           jndi-name="java:jboss/datasources/GreyLegacyDS"/>
    -->
    <subsystem xmlns="urn:jboss:domain:datasources:5.0">
        <datasources>
            <datasource jndi-name="java:jboss/datasources/GreyLegacyDS"
                        pool-name="GreyLegacyPool"
                        enabled="true"
                        use-java-context="true"
                        statistics-enabled="true">

                <connection-url>jdbc:postgresql://db-prod-cluster.greylegacy.internal:5432/greylegacy</connection-url>
                <driver>postgresql</driver>

                <pool>
                    <min-pool-size>10</min-pool-size>
                    <max-pool-size>50</max-pool-size>
                    <prefill>true</prefill>
                    <flush-strategy>IdleConnections</flush-strategy>
                </pool>

                <security>
                    <!--
                        In production, credentials are stored in the JBoss vault:
                          ${VAULT::ds_GreyLegacy::password::1}
                        Plain text shown here for clarity.
                    -->
                    <user-name>greylegacy_app</user-name>
                    <password>VAULT_MANAGED</password>
                </security>

                <validation>
                    <valid-connection-checker class-name="org.jboss.jca.adapters.jdbc.extensions.postgres.PostgreSQLValidConnectionChecker"/>
                    <exception-sorter class-name="org.jboss.jca.adapters.jdbc.extensions.postgres.PostgreSQLExceptionSorter"/>
                    <validate-on-match>false</validate-on-match>
                    <background-validation>true</background-validation>
                    <background-validation-millis>30000</background-validation-millis>
                </validation>

                <timeout>
                    <blocking-timeout-millis>10000</blocking-timeout-millis>
                    <idle-timeout-minutes>5</idle-timeout-minutes>
                    <query-timeout>300</query-timeout>
                </timeout>

                <statement>
                    <prepared-statement-cache-size>100</prepared-statement-cache-size>
                    <share-prepared-statements>true</share-prepared-statements>
                </statement>
            </datasource>

            <drivers>
                <driver name="postgresql" module="org.postgresql">
                    <xa-datasource-class>org.postgresql.xa.PGXADataSource</xa-datasource-class>
                </driver>
            </drivers>
        </datasources>
    </subsystem>

    <!-- ================================================================== -->
    <!-- JMS (ActiveMQ Artemis) Subsystem                                    -->
    <!-- ================================================================== -->
    <!--
        JBoss EAP 7+ ships with Artemis as its built-in JMS broker.
        Queues and topics are defined here and looked up via JNDI.

        For Grey Legacy's external ActiveMQ 5.x broker, JBoss can also
        use a generic JMS resource adapter — but Artemis is shown here
        as the "standard JBoss way."
    -->
    <subsystem xmlns="urn:jboss:domain:messaging-activemq:4.0">
        <server name="default">
            <security-setting name="#">
                <role name="guest"
                      send="true"
                      consume="true"
                      create-non-durable-queue="true"
                      delete-non-durable-queue="true"/>
            </security-setting>

            <!-- Dead Letter and Expiry addresses -->
            <address-setting name="#"
                             dead-letter-address="jms.queue.DLQ"
                             expiry-address="jms.queue.ExpiryQueue"
                             max-size-bytes="104857600"
                             page-size-bytes="2097152"
                             message-counter-history-day-limit="10"
                             redelivery-delay="1000"
                             max-delivery-attempts="5"
                             redistribution-delay="1000"/>

            <jms-queue name="GreyLegacyClaimEvents"
                       entries="java:/jms/queue/ClaimEvents java:jboss/exported/jms/queue/ClaimEvents"/>

            <jms-queue name="GreyLegacyDLQ"
                       entries="java:/jms/queue/DLQ"/>

            <jms-topic name="GreyLegacyClaimNotifications"
                       entries="java:/jms/topic/ClaimNotifications java:jboss/exported/jms/topic/ClaimNotifications"/>

            <!-- Connection factory for application use -->
            <connection-factory name="GreyLegacyConnectionFactory"
                                entries="java:/jms/ConnectionFactory"
                                connectors="in-vm"/>

            <!-- Pooled connection factory for MDB use -->
            <pooled-connection-factory name="activemq-ra"
                                       entries="java:/JmsXA java:jboss/DefaultJMSConnectionFactory"
                                       connectors="in-vm"
                                       transaction="xa"/>
        </server>
    </subsystem>

    <!-- ================================================================== -->
    <!-- Security (JAAS) Subsystem                                           -->
    <!-- ================================================================== -->
    <!--
        JBoss security domains map to JAAS LoginModule chains.
        The Grey Legacy domain uses a DatabaseLoginModule backed by
        the application database's USERS/ROLES tables.

        This is the pre-Elytron security model used in JBoss EAP 6-7.
        EAP 7.1+ can use the newer Elytron subsystem, but most legacy
        deployments still run the PicketBox/JAAS model.
    -->
    <subsystem xmlns="urn:jboss:domain:security:2.0">
        <security-domains>

            <!-- Grey Legacy application security domain -->
            <security-domain name="greylegacy-security" cache-type="default">
                <authentication>
                    <!--
                        Database-backed JAAS LoginModule.
                        Queries APP_USER and APP_USER_ROLE tables.
                    -->
                    <login-module code="Database" flag="required">
                        <module-option name="dsJndiName"
                                       value="java:jboss/datasources/GreyLegacyDS"/>
                        <module-option name="principalsQuery"
                                       value="SELECT PASSWORD FROM APP_USER WHERE USERNAME = ? AND ACTIVE = TRUE"/>
                        <module-option name="rolesQuery"
                                       value="SELECT ROLE_NAME, 'Roles' FROM APP_USER_ROLE WHERE USERNAME = ?"/>
                        <module-option name="hashAlgorithm" value="SHA-256"/>
                        <module-option name="hashEncoding" value="base64"/>
                    </login-module>
                </authentication>
            </security-domain>

            <!-- SOAP web service security domain (WS-Security callbacks) -->
            <security-domain name="greylegacy-ws" cache-type="default">
                <authentication>
                    <login-module code="UsersRoles" flag="required">
                        <module-option name="usersProperties"
                                       value="${jboss.server.config.dir}/greylegacy-ws-users.properties"/>
                        <module-option name="rolesProperties"
                                       value="${jboss.server.config.dir}/greylegacy-ws-roles.properties"/>
                    </login-module>
                </authentication>
            </security-domain>

        </security-domains>
    </subsystem>

    <!-- ================================================================== -->
    <!-- EJB Subsystem                                                       -->
    <!-- ================================================================== -->
    <!--
        Even though Grey Legacy is primarily Spring-based, many legacy
        insurance systems have EJB session beans for transactional
        boundaries and JMS message-driven beans (MDBs).
    -->
    <subsystem xmlns="urn:jboss:domain:ejb3:5.0">
        <session-bean>
            <stateless>
                <bean-instance-pool-ref pool-name="slsb-strict-max-pool"/>
            </stateless>
            <stateful default-access-timeout="5000"
                      cache-ref="simple"
                      passivation-disabled-cache-ref="simple"/>
        </session-bean>
        <mdb>
            <resource-adapter-ref resource-adapter-name="${ejb.resource-adapter-name:activemq-ra.rar}"/>
            <bean-instance-pool-ref pool-name="mdb-strict-max-pool"/>
        </mdb>
        <pools>
            <bean-instance-pools>
                <strict-max-pool name="slsb-strict-max-pool"
                                 max-pool-size="20"
                                 instance-acquisition-timeout="5"
                                 instance-acquisition-timeout-unit="MINUTES"/>
                <strict-max-pool name="mdb-strict-max-pool"
                                 max-pool-size="20"
                                 instance-acquisition-timeout="5"
                                 instance-acquisition-timeout-unit="MINUTES"/>
            </bean-instance-pools>
        </pools>
        <thread-pools>
            <thread-pool name="default">
                <max-threads count="10"/>
                <keepalive-time time="100" unit="milliseconds"/>
            </thread-pool>
        </thread-pools>
    </subsystem>

    <!-- ================================================================== -->
    <!-- Web (Undertow) Subsystem                                            -->
    <!-- ================================================================== -->
    <subsystem xmlns="urn:jboss:domain:undertow:7.0">
        <server name="default-server">
            <http-listener name="default"
                           socket-binding="http"
                           redirect-socket="https"
                           max-post-size="10485760"/>
            <https-listener name="https"
                            socket-binding="https"
                            security-realm="ApplicationRealm"
                            max-post-size="10485760"/>
            <host name="default-host" alias="localhost">
                <access-log pattern="%h %l %u %t &quot;%r&quot; %s %b %D"
                            directory="${jboss.home.dir}/standalone/log"
                            prefix="access"/>
                <!-- Filter: security headers for compliance -->
                <filter-ref name="security-headers"/>
            </host>
        </server>
        <filters>
            <response-header name="security-headers"
                             header-name="X-Frame-Options"
                             header-value="DENY"/>
        </filters>
    </subsystem>

    <!-- ================================================================== -->
    <!-- Logging Subsystem                                                   -->
    <!-- ================================================================== -->
    <subsystem xmlns="urn:jboss:domain:logging:6.0">
        <periodic-rotating-file-handler name="GREYLEGACY_FILE"
                                         autoflush="true">
            <formatter>
                <named-formatter name="PATTERN"/>
            </formatter>
            <file relative-to="jboss.server.log.dir" path="greylegacy.log"/>
            <suffix value=".yyyy-MM-dd"/>
            <append value="true"/>
        </periodic-rotating-file-handler>

        <logger category="com.greylegacy" use-parent-handlers="false">
            <level name="DEBUG"/>
            <handlers>
                <handler name="GREYLEGACY_FILE"/>
                <handler name="CONSOLE"/>
            </handlers>
        </logger>

        <!-- Reduce noise from frameworks -->
        <logger category="org.hibernate.SQL">
            <level name="DEBUG"/>
        </logger>
        <logger category="org.springframework">
            <level name="WARN"/>
        </logger>
        <logger category="org.apache.cxf">
            <level name="WARN"/>
        </logger>
    </subsystem>

</server>
