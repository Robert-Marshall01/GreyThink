        <c3p0.version>0.9.5.5</c3p0.version>
        <h2.version>1.4.200</h2.version>
        <postgresql.version>42.2.24</postgresql.version>

        <!-- SOAP / Web Services -->
        <cxf.version>3.2.14</cxf.version>
        <jaxb.version>2.3.1</jaxb.version>
        <jaxws.version>2.3.1</jaxws.version>

        <!-- Servlet / JSP -->
        <servlet.version>3.1.0</servlet.version>
        <jsp.version>2.3.1</jsp.version>
        <jstl.version>1.2</jstl.version>

        <!-- Logging -->
        <slf4j.version>1.7.36</slf4j.version>
        <log4j.version>1.2.17</log4j.version>

        <!-- Batch -->
        <quartz.version>2.3.2</quartz.version>
        <spring.batch.version>3.0.10.RELEASE</spring.batch.version>

        <!-- JMS -->
        <activemq.version>5.15.16</activemq.version>
        <jms.api.version>1.1</jms.api.version>

        <!-- SFTP -->
        <jsch.version>0.1.55</jsch.version>

        <!-- Testing -->
        <junit.version>4.13.2</junit.version>
        <mockito.version>2.28.2</mockito.version>

        <!-- Utilities -->
        <commons.lang.version>2.6</commons.lang.version>
        <commons.collections.version>3.2.2</commons.collections.version>
        <commons.io.version>2.11.0</commons.io.version>
        <commons.dbcp.version>1.4</commons.dbcp.version>
        <jackson.version>2.9.10.8</jackson.version>

        <!-- MyBatis (hybrid ORM strategy) -->
        <mybatis.version>3.5.11</mybatis.version>
        <mybatis.spring.version>2.0.7</mybatis.spring.version>

        <!-- Apache Camel (enterprise integration) -->
        <camel.version>2.25.4</camel.version>

        <!-- Hibernate L2 Cache -->
        <ehcache.version>2.10.9.2</ehcache.version>
        <hibernate.ehcache.version>${hibernate.version}</hibernate.ehcache.version>

        <!-- WS-Security -->
        <wss4j.version>2.2.7</wss4j.version>
        <cxf.rt.ws.security.version>${cxf.version}</cxf.rt.ws.security.version>
    </properties>

