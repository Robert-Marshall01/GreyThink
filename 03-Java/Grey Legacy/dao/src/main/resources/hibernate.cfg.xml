<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
    "-//Hibernate/Hibernate Configuration 3.0//EN"
    "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <!-- Database connection settings (overridden by Spring in production) -->
        <property name="hibernate.connection.driver_class">org.h2.Driver</property>
        <property name="hibernate.connection.url">jdbc:h2:mem:greylegacy</property>
        <property name="hibernate.connection.username">sa</property>
        <property name="hibernate.connection.password"></property>

        <!-- SQL dialect -->
        <property name="hibernate.dialect">org.hibernate.dialect.H2Dialect</property>

        <!-- Echo all executed SQL to stdout -->
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
        <property name="hibernate.use_sql_comments">true</property>

        <!-- DDL auto -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- C3P0 Connection Pool -->
        <property name="hibernate.c3p0.min_size">5</property>
        <property name="hibernate.c3p0.max_size">20</property>
        <property name="hibernate.c3p0.timeout">300</property>
        <property name="hibernate.c3p0.max_statements">100</property>

        <!-- Batch settings for performance -->
        <property name="hibernate.jdbc.batch_size">25</property>
        <property name="hibernate.order_inserts">true</property>
        <property name="hibernate.order_updates">true</property>
        <property name="hibernate.jdbc.batch_versioned_data">true</property>

        <!-- Second-level cache (disabled for simplicity) -->
        <property name="hibernate.cache.use_second_level_cache">false</property>
        <property name="hibernate.cache.use_query_cache">false</property>

        <!-- Mapping files -->
        <mapping resource="hibernate-mappings/Policy.hbm.xml"/>
        <mapping resource="hibernate-mappings/Claim.hbm.xml"/>
        <mapping resource="hibernate-mappings/ClaimPayment.hbm.xml"/>

        <!-- Annotated classes (dual mapping demonstration) -->
        <mapping class="com.greylegacy.domain.Policy"/>
        <mapping class="com.greylegacy.domain.Claim"/>
        <mapping class="com.greylegacy.domain.ClaimPayment"/>
        <mapping class="com.greylegacy.domain.ClaimAuditEntry"/>
        <mapping class="com.greylegacy.domain.ClaimNote"/>
        <mapping class="com.greylegacy.domain.ClaimSnapshot"/>
        <mapping class="com.greylegacy.domain.PolicyEndorsement"/>
        <mapping class="com.greylegacy.domain.Adjuster"/>
    </session-factory>
</hibernate-configuration>
