    <artifactId>grey-legacy-parent</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>pom</packaging>

    <name>Grey Legacy - Enterprise Claims Processing System</name>
    <description>
        Multi-module enterprise insurance claims processing monolith.
        Demonstrates legacy Java EE patterns: Struts, Hibernate, Spring XML DI,
        SOAP/WSDL integrations, batch processing, and JDBC connection pooling.
    </description>

    <modules>
        <module>domain</module>
        <module>dao</module>
        <module>service</module>
        <module>web</module>
        <module>batch</module>
        <module>integration</module>
        <module>ear</module>
        <module>modernization</module>
    </modules>

