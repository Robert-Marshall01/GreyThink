    <!-- ================================================================== -->
    <!-- Maven Profiles: Environment-Specific Configuration                -->
    <!-- ================================================================== -->
    <profiles>
        <!-- Development Profile (default) -->
        <profile>
            <id>dev</id>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
            <properties>
                <db.driver>org.h2.Driver</db.driver>
                <db.url>jdbc:h2:mem:greylegacy;DB_CLOSE_DELAY=-1</db.url>
                <db.username>sa</db.username>
                <db.password></db.password>
                <hibernate.dialect>org.hibernate.dialect.H2Dialect</hibernate.dialect>
                <hibernate.hbm2ddl.auto>create-drop</hibernate.hbm2ddl.auto>
                <hibernate.show_sql>true</hibernate.show_sql>
                <log.level>DEBUG</log.level>
                <jms.broker.url>vm://localhost?broker.persistent=false</jms.broker.url>
            </properties>
        </profile>

        <!-- Staging Profile -->
        <profile>
            <id>staging</id>
            <properties>
                <db.driver>org.postgresql.Driver</db.driver>
                <db.url>jdbc:postgresql://staging-db:5432/greylegacy</db.url>
                <db.username>gl_app</db.username>
                <db.password>${env.DB_PASSWORD}</db.password>
                <hibernate.dialect>org.hibernate.dialect.PostgreSQL95Dialect</hibernate.dialect>
                <hibernate.hbm2ddl.auto>validate</hibernate.hbm2ddl.auto>
                <hibernate.show_sql>false</hibernate.show_sql>
                <log.level>INFO</log.level>
                <jms.broker.url>tcp://staging-mq:61616</jms.broker.url>
            </properties>
        </profile>

        <!-- Production Profile -->
        <profile>
            <id>prod</id>
            <properties>
                <db.driver>org.postgresql.Driver</db.driver>
                <db.url>jdbc:postgresql://prod-db-cluster:5432/greylegacy</db.url>
                <db.username>gl_prod</db.username>
                <db.password>${env.DB_PASSWORD}</db.password>
                <hibernate.dialect>org.hibernate.dialect.PostgreSQL95Dialect</hibernate.dialect>
                <hibernate.hbm2ddl.auto>none</hibernate.hbm2ddl.auto>
                <hibernate.show_sql>false</hibernate.show_sql>
                <log.level>WARN</log.level>
                <jms.broker.url>failover:(tcp://prod-mq-01:61616,tcp://prod-mq-02:61616)</jms.broker.url>
            </properties>
        </profile>

        <!-- Integration Test Profile -->
        <profile>
            <id>integration-tests</id>
            <properties>
                <db.driver>org.h2.Driver</db.driver>
                <db.url>jdbc:h2:mem:greylegacy_it;DB_CLOSE_DELAY=-1</db.url>
                <db.username>sa</db.username>
                <db.password></db.password>
                <hibernate.dialect>org.hibernate.dialect.H2Dialect</hibernate.dialect>
                <hibernate.hbm2ddl.auto>create-drop</hibernate.hbm2ddl.auto>
                <hibernate.show_sql>true</hibernate.show_sql>
                <log.level>DEBUG</log.level>
            </properties>
        </profile>
    </profiles>

